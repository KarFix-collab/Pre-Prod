# KarFix — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!

# =============================================================================
# FLASK APPLICATION
# =============================================================================

FLASK_ENV=development
SECRET_KEY=your-secret-key-generate-with-python-c-import-secrets-print-secrets-token-hex-32

# Server binding (local development only)
HOST=127.0.0.1
PORT=5000

# =============================================================================
# DATABASE — Supabase PostgreSQL
# =============================================================================

# Use the Session Pooler connection string from:
#   Supabase Dashboard → Project Settings → Database → Connection string → URI
# Choose the Session pooler (port 6543), not the Transaction pooler (5432).
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Alternative: individual variables (used if DATABASE_URL is not set)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=your-password
# DB_NAME=postgres

# SSL mode: require (cloud), prefer (local), disable (testing)
DB_SSLMODE=require

# =============================================================================
# PLATFORM BOOTSTRAP SUPERADMIN
# =============================================================================
# Create a dedicated platform administrator account in Supabase Auth that does
# NOT belong to any tenant. The app will promote the matching local profile on
# first Supabase login.
# This bootstrap is idempotent and only runs when enabled.
SUPERADMIN_BOOTSTRAP_ENABLED=true
SUPERADMIN_EMAIL=admin@karfix.local
SUPERADMIN_PASSWORD=ChangeMeImmediately!
SUPERADMIN_USERNAME=admin

# Optional: if email confirmation is enabled in Supabase, the bootstrap account
# may require confirmation before the first login succeeds.

# =============================================================================
# SUPABASE AUTH
# =============================================================================

# Project URL — e.g. https://xxxx.supabase.co
# Found in: Supabase Dashboard → Settings → API
SUPABASE_URL=https://xxxx.supabase.co

# Public anon key — safe to include in browser JS
# Found in: Supabase Dashboard → Settings → API → Project API keys → anon public
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — server-side only, never expose in browser
# Found in: Supabase Dashboard → Settings → API → Project API keys → service_role
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# JWT secret — server-side only, never expose in browser
# Found in: Supabase Dashboard → Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# =============================================================================
# GOOGLE OAUTH — Direct OAuth Integration for Flask
# =============================================================================

# Get these from Google Cloud Console:
# https://console.cloud.google.com/apis/credentials
#
# 1. Create a new OAuth 2.0 Client ID
# 2. Set Authorised redirect URIs to:
#    - http://localhost:5000/auth/google/callback  (development)
#    - https://<your-render-url>/auth/google/callback  (production)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# =============================================================================
# LOGGING
# =============================================================================

LOG_LEVEL=INFO

# Set to true for Render / cloud deployments (logs go to stdout)
LOG_TO_STDOUT=false

# =============================================================================
# RENDER DEPLOYMENT NOTES
# =============================================================================
#
# Render injects PORT automatically — do not set it manually.
#
# Set the following in the Render dashboard (Environment tab) or via render.yaml:
#
#   SECRET_KEY        auto-generated by Render (generateValue: true)
#   FLASK_ENV         production
#   LOG_TO_STDOUT     true
#   DATABASE_URL      your Supabase session-pooler URL
#   SUPABASE_URL      https://xxxx.supabase.co
#   SUPABASE_ANON_KEY eyJ...
#   SUPABASE_JWT_SECRET  <from Supabase Dashboard → Settings → API → JWT Secret>
#   GOOGLE_CLIENT_ID  your-client-id.apps.googleusercontent.com
#   GOOGLE_CLIENT_SECRET  your-secret

# =============================================================================
# EMAIL / INVOICE DELIVERY
# =============================================================================
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your-smtp-username
MAIL_PASSWORD=your-smtp-password
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_FROM=billing@karfix.local
MAIL_FROM_NAME=KarFix Invoicing
